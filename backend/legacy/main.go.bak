package main

import (
	"log"
	"net/http"
	"os"

	"taretan-backend/config"
	"taretan-backend/models"

	"github.com/gin-gonic/gin"
	"github.com/joho/godotenv"
)

func main() {
	// Load environment variables
	err := godotenv.Load()
	if err != nil {
		log.Println("No .env file found or error loading it, relying on system environment variables")
	}

	// Connect to Database
	config.ConnectDatabase()

	// Run Migrations (Wait, we should only migrate if needed, but for dev it's fine)
	err = models.MigrateAll(config.DB)
	if err != nil {
		log.Fatalf("AutoMigration failed: %v", err)
	}

	// Wait for routes
	r := gin.Default()

	// Health Check
	r.GET("/api/ping", func(c *gin.Context) {
		c.JSON(http.StatusOK, gin.H{
			"message": "pong",
			"status":  "Taretan API is running",
		})
	})

	// Start server
	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}

	log.Printf("Server listening on port %s", port)
	r.Run(":" + port)
}
